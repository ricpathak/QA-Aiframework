ENVIRONMENT=dev

# SECRET_KEY must be set in your shell or CI secrets — never put it in this file
# export SECRET_KEY=your-master-encryption-key
# To encrypt credentials in this file: npm run credentials:encrypt -- environments/example.env
# To verify encrypted values: npm run credentials:verify -- environments/example.env

APP_BASE_URL=https://your-app.example.com
APP_LOGIN_URL=https://your-app.example.com/login
APP_USERNAME=standard_user
APP_PASSWORD=secret_sauce

PLAYWRIGHT_DEV_URL=https://playwright.dev/
DEMO_PLAYWRIGHT_DEV_URL=https://demo.playwright.dev/todomvc/
API_BASE_URL=https://jsonplaceholder.typicode.com

SAUCE_DEMO_URL=https://www.saucedemo.com/
SAUCE_DEMO_USERNAME=standard_user
SAUCE_DEMO_LOCKED_OUT_USERNAME=locked_out_user
SAUCE_DEMO_PASSWORD=secret_sauce

# Confluence export settings (used by confluence:fetch script)
# CONFLUENCE_PASSWORD: for Confluence Cloud use your API token; for Server/DC use your actual password
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_PAGE_ID=
CONFLUENCE_USERNAME=
CONFLUENCE_PASSWORD=
