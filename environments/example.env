# Confluence export settings (used by confluence:fetch script)
# CONFLUENCE_BASE_URL: your Confluence root, e.g. https://your-domain.atlassian.net
# CONFLUENCE_PASSWORD: for Confluence Cloud this is your API token; for Server/DC it is your actual password
CONFLUENCE_BASE_URL=https://your-confluence-instance.atlassian.net
CONFLUENCE_PAGE_ID=
CONFLUENCE_USERNAME=
CONFLUENCE_PASSWORD=
