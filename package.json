{
	"name": "qa-aiframework",
	"version": "1.0.0",
	"description": "AI-augmented QA engineering platform — Playwright + TypeScript + MCP agent pipeline for automated test planning, generation, execution, and self-healing",
	"scripts": {
		"setup": "npm ci && npx playwright install && npm run mcp:build",
		"prettier": "npx prettier --check .",
		"prettier:fix": "npx prettier --write .",
		"eslint": "npx eslint .",
		"eslint:fix": "npx eslint . --fix",
		"test": "npx playwright test",
		"test:local": "npx cross-env NODE_ENV=local playwright test",
		"test:dev": "npx cross-env NODE_ENV=dev playwright test",
		"test:qa": "npx cross-env NODE_ENV=qa playwright test",
		"test:headed": "npx playwright test --headed",
		"test:ui": "npx playwright test --ui",
		"test:debug": "npx playwright test --debug",
		"test:trace": "npx playwright test --trace",
		"test:custom": "ts-node utils/run-custom-tests.ts",
		"test:report:playwright": "playwright show-report reports/playwright-report",
		"test:report:custom": "open-cli reports/index.html",
		"validate:generated": "ts-node utils/validate-generated-tests.ts",
		"confluence:fetch": "ts-node utils/confluence-to-md.ts",
		"excel:fetch": "ts-node utils/excel-to-md.ts",
		"credentials:encrypt": "ts-node utils/encrypt-credentials.ts",
		"credentials:verify": "ts-node utils/encrypt-credentials.ts --verify",
		"mcp:build": "cd mcp-server && npm install && npm run build",
		"mcp:start": "node mcp-server/dist/index.js",
		"prepare": "husky install"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ricpathak/qa-aiframework.git"
	},
	"keywords": ["playwright", "typescript", "test-automation", "mcp", "ai-agents", "qa", "page-object-model"],
	"author": "ricpathak",
	"license": "UNLICENSED",
	"bugs": {
		"url": "https://github.com/ricpathak/qa-aiframework/issues"
	},
	"homepage": "https://github.com/ricpathak/qa-aiframework#readme",
	"devDependencies": {
		"@eslint/js": "^9.24.0",
		"@playwright/test": "^1.59.1",
		"@types/node": "^24.0.3",
		"@typescript-eslint/eslint-plugin": "^8.29.1",
		"@typescript-eslint/parser": "^8.29.1",
		"eslint": "^9.24.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-prettier": "^5.2.6",
		"globals": "^16.0.0",
		"husky": "^8.0.0",
		"lint-staged": "^16.1.0",
		"open-cli": "^8.0.0",
		"prettier": "^3.5.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.29.1",
		"@types/turndown": "^5.0.5"
	},
	"dependencies": {
		"axios": "^1.9.0",
		"cross-env": "^7.0.3",
		"dotenv": "^16.4.7",
		"inquirer": "^12.5.2",
		"exceljs": "^4.4.0",
		"turndown": "^7.2.0"
	}
}
